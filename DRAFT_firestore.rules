rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: Prioritize the hardcoded email for initial setup, then fallback to DB lookup
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jashimmirza@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['user', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidAccessRequest(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'status', 'requestedAt']) &&
             data.keys().size() >= 4 &&
             isValidId(data.userId) &&
             data.userId == request.auth.uid &&
             data.userEmail is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.requestedAt == request.time;
    }

    function isValidUsageLog(data) {
      return data.keys().hasAll(['userId', 'date', 'count']) &&
             data.keys().size() >= 3 &&
             isValidId(data.userId) &&
             data.userId == request.auth.uid &&
             data.date is string && data.date.size() <= 20 &&
             data.count is int && data.count >= 0;
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // Identity Protection: Only the user or an admin can read the profile
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // List Guard: Secure query enforcement
      allow list: if isAdmin(); // Regular users shouldn't be listing profiles

      // Write Security: Mandatory verification for creation
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming());
      
      // Tiered Update: Regular users can't change their role
      allow update: if (isAdmin() || (
        isVerified() && 
        request.auth.uid == userId && 
        isValidUser(incoming()) &&
        incoming().role == existing().role && // Immutable role for self
        incoming().createdAt == existing().createdAt && // Immutable timestamp
        incoming().diff(existing()).affectedKeys().hasOnly(['email', 'accessExpiresAt', 'role', 'createdAt'])
        // Note: The above is broad for admin updates, but for self-update we might restrict further
      )) && (
        // Action: Self Update (limit to email if needed)
        (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['email']))
      );
    }

    // 2. Access Requests
    match /accessRequests/{requestId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isVerified() && isValidAccessRequest(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 3. Usage Logs
    match /usageLogs/{logId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isVerified() && isValidUsageLog(incoming()) && (
        // The logId naming convention enforcement
        logId.startsWith(request.auth.uid)
      );
      
      allow update: if (isAdmin() || (
        isVerified() && 
        resource.data.userId == request.auth.uid &&
        isValidUsageLog(incoming()) &&
        incoming().userId == existing().userId &&
        incoming().date == existing().date &&
        // Action: Increment Count
        incoming().diff(existing()).affectedKeys().hasOnly(['count'])
      ));
    }
  }
}
